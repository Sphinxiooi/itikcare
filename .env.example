DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=itikcare
DB_USER=itikcare_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306

# Optional: farm's fixed GPS coordinates. Used only to prefill temperature_c/humidity_pct
# on the daily log form from a live weather API (Open-Meteo, no API key needed). Leave
# blank to disable the prefill -- the farmer can still type these fields in by hand.
FARM_LATITUDE=
FARM_LONGITUDE=

# Optional: "Sign in with Google" (see DEPLOYMENT.md for how to create these in Google
# Cloud Console). Leave both blank to hide the button entirely -- local username/
# password signup and login keep working either way.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Production deployment only (see DEPLOYMENT.md) ---
# Leave all of the below unset for local dev; they default to safe/off values.

# Once served from a real domain, list it here (with scheme) so Django accepts POSTs
# from it, e.g. https://itikcare.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Flip these on in this order, one at a time, only after confirming HTTPS actually
# works through your reverse proxy -- see DEPLOYMENT.md's rollout order.
DJANGO_BEHIND_PROXY=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0

# Optional: real SMTP for password-reset emails. Leave DJANGO_EMAIL_HOST blank to print
# emails to the console instead (fine for local dev and for a first deployment).
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=webmaster@localhost

# Optional: who gets emailed on an unhandled 500 once DJANGO_DEBUG=False. Format:
# "Name One:one@example.com,Name Two:two@example.com"
DJANGO_ADMINS=
DJANGO_SERVER_EMAIL=webmaster@localhost
