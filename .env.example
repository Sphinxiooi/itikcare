DB_HOST=localhost
DB_PORT=3306

# Optional: farm's fixed GPS coordinates. Used only to prefill temperature_c/humidity_pct
# on the daily log form from a live weather API (Open-Meteo, no API key needed). Leave
# blank to disable the prefill -- the farmer can still type these fields in by hand.
FARM_LATITUDE=
FARM_LONGITUDE=
